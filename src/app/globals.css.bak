@import "tailwindcss";

@theme {
  --color-neon-cyan: #00f2ff;
  --color-neon-purple: #b026ff;
  --color-premium-dark: #050505;
  --color-glass: rgba(255, 255, 255, 0.05);

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 15px rgba(0, 242, 255, 0.2); }
    50% { box-shadow: 0 0 30px rgba(0, 242, 255, 0.5); }
  }
  
  --animate-float: float 6s ease-in-out infinite;
  --animate-pulse-glow: pulse-glow 3s ease-in-out infinite;
}

:root {
  --foreground: #ffffff;
  --background: #050505;
}

body {
  color: var(--foreground);
  background: var(--background);
  font-family: 'Inter', sans-serif;
  overflow-x: hidden;
}

.glass {
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.glass-card {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.01) 100%);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.8);
}

.neon-border-cyan {
  border: 1px solid rgba(0, 242, 255, 0.3);
  box-shadow: 0 0 15px rgba(0, 242, 255, 0.1);
}

.neon-border-purple {
  border: 1px solid rgba(176, 38, 255, 0.3);
  box-shadow: 0 0 15px rgba(176, 38, 255, 0.1);
}

/* Custom Scrollbar */
::-webkit-scrollbar {
  width: 6px;
}
::-webkit-scrollbar-track {
  background: #050505;
}
::-webkit-scrollbar-thumb {
  background: #222;
  border-radius: 10px;
}
::-webkit-scrollbar-thumb:hover {
  background: #333;
}
